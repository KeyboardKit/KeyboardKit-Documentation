he predefined "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Proxy\/FullDocumentReaderConfiguration\/standard"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Proxy\/FullDocumentReaderConfiguration\/fast"},{"type":"text","text":" configs."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Proxy\/FullDocumentReaderConfiguration\/endOfProxyAttempts"},{"type":"text","text":" determines how many times"},{"type":"text","text":" "},{"type":"text","text":"to attempt to move the text cursor when reaching the"},{"type":"text","text":" "},{"type":"text","text":"beginning or the end of the proxy. This is needed to"},{"type":"text","text":" "},{"type":"text","text":"handle texts that have many line breaks, since these"},{"type":"text","text":" "},{"type":"text","text":"line breaks can otherwise cause the operation to end."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The standard "},{"type":"codeVoice","code":"10"},{"type":"text","text":" attempts will make a proxy attempt"},{"type":"text","text":" "},{"type":"text","text":"to move the cursor that many times, but it will fail"},{"type":"text","text":" "},{"type":"text","text":"if there are more paragraphs. Using more attempts is"},{"type":"text","text":" "},{"type":"text","text":"however taking longer to complete."}],"type":"paragraph"}],"kind":"content"}],"references":{"Feature-Proxy.jpg":{"variants":[{"url":"\/images\/com.keyboardkit.KeyboardKit\/Feature-Proxy.jpg","traits":["1x","light"]}],"identifier":"Feature-Proxy.jpg","alt":"Feature Icon","type":"image"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Proxy/FullDocumentReaderConfiguration/sleepInterval":{"abstract":[{"text":"How long to slee