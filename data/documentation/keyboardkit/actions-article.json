fier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Vietnamese","isActive":true},{"type":"text","text":" TELEX, VNI & VIQR text input and adds this support to the action handler. You can sign up for KeyboardKit Pro from the "},{"type":"reference","identifier":"https:\/\/keyboardkit.com","isActive":true},{"type":"text","text":"."}]}],"type":"aside","name":"Important"},{"anchor":"Developer-Guide","level":2,"text":"Developer Guide","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Actions","isActive":true},{"type":"text","text":" developer guide has step-by-step instructions on how to customize the action handling with a custom action handler."}]},{"anchor":"Namespace","level":2,"text":"Namespace","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction","isActive":true},{"type":"text","text":" enum that defines keyboard-related actions. It also serves as a namespace for other action-related types and views, like the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/StandardActionHandler","isActive":true},{"type":"text","text":" that can be used to handle many actions."}]},{"anchor":"Actions","level":2,"text":"Actions","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction","isActive":true},{"type":"text","text":" enum defines many keyboard-related actions, like "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/backspace","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/character(_:)","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/dismissKeyboard","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/emoji(_:)-swift.enum.case","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/keyboardType(_:)","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/nextKeyboard","isActive":true},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/nextLocale","isActive":true},{"type":"text","text":", etc. See "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction","isActive":true},{"type":"text","text":" for a full list of actions."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many actions have a "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/standardAction","isActive":true},{"type":"text","text":", while others require manual handling by creating a custom "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardActionHandler","isActive":true},{"type":"text","text":"."}]},{"anchor":"Action-Handlers","level":2,"text":"Action Handlers","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In KeyboardKit, a "},{"type":"reference","identifier":"doc:\/\/com.keyboardk