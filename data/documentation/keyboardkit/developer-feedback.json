{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"This developer guide describes how to customize keyboard feedback.","type":"text"}],"kind":"article","seeAlsoSections":[{"generated":true,"title":"Feature Customizations","anchor":"Feature-Customizations","identifiers":["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Actions","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Autocomplete","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Dictation","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Localization","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Themes"]}],"variants":[{"paths":["\/documentation\/keyboardkit\/developer-feedback"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/keyboardkit\/developer-feedback"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Feedback","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Feedback is an important part of a keyboard typing experience. See the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback-Article","type":"reference"},{"text":" article for information about the keyboard feedback feature and its many capabilities.","type":"text"}]},{"level":2,"anchor":"How-to-trigger-keyboard-feedback","text":"How to trigger keyboard feedback","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"You can trigger ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback\/Audio","type":"reference"},{"text":" & ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback\/Haptic","type":"reference"},{"text":" feedback with a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/FeedbackService","type":"reference"},{"text":" or by using the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardActionHandler","type":"reference"},{"type":"text","text":". The standard action handler will trigger feedback for all actions that it handles, in accordance to the current "},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/FeedbackContext\/settings","type":"reference"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Use "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/FeedbackService\/triggerAudioFeedback(_:)","isActive":true,"type":"reference"},{"type":"text","text":" to trigger audio feedback, "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/FeedbackService\/triggerHapticFeedback(_:)","type":"reference","isActive":true},{"type":"text","text":" to trigger haptic feedback, and the action handler’s "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardActionHandler\/triggerFeedback(for:on:)","type":"reference","isActive":true},{"text":" to trigger feedback for a specific action.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"How-to-customize-keyboard-feedback","text":"How to customize keyboard feedback","type":"heading"},{"inlineContent":[{"text":"You can configure the main ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Keyboard\/State\/feedbackContext","isActive":true,"type":"reference"},{"text":" and its ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/FeedbackContext\/settings","isActive":true,"type":"reference"},{"text":" to change the feedback behavior. For instance, this will customize the audio feedback for input keys, then disable haptic feedback:","type":"text"}],"type":"paragraph"},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.audioConfiguration.input = .custom(id: 1329)","        context.settings.isHapticFeedbackEnabled = false","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"You can also use use the context to register custom feedback for any gesture on any action.","type":"text"}],"type":"paragraph"},{"code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        let context = state.feedbackContext","        context.registerCustomFeedback(.audio(.rocketFuse, for: .press, on: .rocket))","        context.registerCustomFeedback(.audio(.rocketLaunch, for: .release, on: .rocket))","        context.registerCustomFeedback(.haptic(.selection, for: .repeat, on: .rocket))","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Since the configuration is observable, any changes will automatically cause the keyboard to update, e.g. if you have feedback toggles.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"How-to-define-custom-audio-feedback","text":"How to define custom audio feedback","type":"heading"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback\/Audio","isActive":true,"type":"reference"},{"text":" feedback type uses ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"AudioServices"}]},{"text":", which means you can use any system audio (see ","type":"text"},{"identifier":"https:\/\/iphonedev.wiki\/index.php\/AudioServices","isActive":true,"type":"reference"},{"text":") as custom audio feedback:","type":"text"}],"type":"paragraph"},{"code":["extension Feedback.Audio {","","    static let sentMessage = .custom(id: 1004)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"You can also use the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback\/Audio\/customUrl(_:)","isActive":true,"type":"reference"},{"text":" feedback type to define a custom audio feedback that loads a sound effect from an audio file:","type":"text"}],"type":"paragraph"},{"code":["extension Feedback.Audio {","","    static let sentMessage = .customUrl(","        Bundle.main.url(forResource: \"sent\", withExtension: \"mp3\")","    )","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"You can also implement a custom action handler to trigger feedback in a different ways. See the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Actions-Article","isActive":true,"type":"reference"},{"text":" article for more information.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Articles"],["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Features-Articles","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Feedback-Article"]]},"metadata":{"title":"Feedback","color":{"standardColorIdentifier":"purple"},"images":[{"identifier":"Feature-Feedback.jpg","type":"card"}],"roleHeading":"Article","modules":[{"name":"KeyboardKit"}],"role":"article"},"references":{"Feature-Themes.jpg":{"type":"image","alt":"Article Icon","identifier":"Feature-Themes.jpg","variants":[{"url":"\/images\/com.keyboardkit.KeyboardKit\/Feature-Themes.jpg","traits":["1x","light"]