{"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"This developer guide describes how to get started with KeyboardKit.","type":"text"}],"kind":"article","seeAlsoSections":[{"anchor":"Articles","identifiers":["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Essentials-Article","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Features-Articles","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Articles"],"generated":true,"title":"Articles"}],"variants":[{"paths":["\/documentation\/keyboardkit\/getting-started-article"],"traits":[{"interfaceLanguage":"swift"}]},{"paths":["\/documentation\/keyboardkit\/getting-started-article"],"traits":[{"interfaceLanguage":"occ"}]}],"sections":[],"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Getting-Started-Article","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"anchor":"overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide goes through all the steps involved in adding KeyboardKit to your project and setting it up for the main app and its keyboard."}]},{"anchor":"Step-1-Add-KeyboardKit-to-your-project","type":"heading","level":2,"text":"Step 1. Add KeyboardKit to your project"},{"inlineContent":[{"type":"text","text":"KeyboardKit can be installed with the Swift Package Manager:"}],"type":"paragraph"},{"code":["https:\/\/github.com\/KeyboardKit\/KeyboardKit.git"],"type":"codeListing","syntax":null},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"KeyboardKit is a binary target and must ONLY be added to the app target. If you add it to any other target, it may crash at runtime.","type":"text"}]}]},{"text":"Step 2. Define app-specific information","anchor":"Step-2-Define-app-specific-information","type":"heading","level":2},{"inlineContent":[{"text":"The easiest way to set up KeyboardKit is with a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp"},{"text":" that can define an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/appGroupId"},{"text":", a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/licenseKey"},{"text":", ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/deepLinks-swift.property"},{"type":"text","text":", etc."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit","","extension KeyboardApp {","","    static var myApp: KeyboardApp {","        .init(","            name: \"My App\",","            licenseKey: \"your-license-key\",             \/\/ Unlocks KeyboardKit Pro","            appGroupId: \"group.com.myapp\",              \/\/ Sets up App Group data sync","            locales: .keyboardKitSupported,             \/\/ Sets up the enabled locales","            autocomplete: .init(                        \/\/ Sets up autocomplete addons  ","                nextWordPredictionRequest: .claude(...) \/\/ Sets up AI-based prediction","            ),","            deepLinks: .init(app: \"myapp:\/\/\", ...)      \/\/ Defines how to open the app","        )","    }","}"]},{"inlineContent":[{"type":"text","text":"Define this in a file that you add to your app "},{"type":"emphasis","inlineContent":[{"text":"and","type":"text"}]},{"text":" keyboard extension, to be able to use it in both targets. See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/App-Article"},{"text":" for more info.","type":"text"}],"type":"paragraph"},{"anchor":"Step-3-Set-up-the-keyboard-extension","type":"heading","level":2,"text":"Step 3. Set up the keyboard extension"},{"type":"paragraph","inlineContent":[{"text":"To use KeyboardKit, first make your controller inherit ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController","type":"reference","isActive":true},{"text":" instead of ","type":"text"},{"code":"UIInputViewController","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import KeyboardKit","","class KeyboardController: KeyboardInputViewController {}"]},{"type":"paragraph","inlineContent":[{"text":"This adds tons of capabilities to the controller, new lifecycle functions, as well as keyboard-specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":" and observable ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can now set up KeyboardKit for your ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","isActive":true,"type":"reference"},{"text":", by calling ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/setup(for:completion:)","isActive":true,"type":"reference"},{"text":" in ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/viewDidLoad()","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .myApp) { result in","            \/\/ If the result is `.success`, the setup succeeded.","            \/\/ This is where you can setup custom services, etc.","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This will unlock KeyboardKit Pro if the app defines a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/licenseKey","isActive":true,"type":"reference"},{"text":", set up ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardSettings","isActive":true,"type":"reference"},{"text":" to automatically sync data between the app and keyboard if the app defines an ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/appGroupId","isActive":true,"type":"reference"},{"text":", register ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/deepLinks-swift.property","isActive":true,"type":"reference"},{"text":", set up ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation-Article","isActive":true,"type":"reference"},{"text":", etc.","type":"text"}]},{"style":"tip","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You don’t have to add a KeyboardKit Pro "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/licenseKey","type":"reference","isActive":true},{"type":"text","text":" if you have a license file. KeyboardKit automatically finds and uses that file."}]}],"type":"aside","name":"Tip"},{"type":"paragraph","inlineContent":[{"text":"The completion result will either be successful with more information, like a successfully validated ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/License","isActive":true,"type":"reference"},{"text":", or return an error. You can start using KeyboardKit Pro features as soon as the completion is called with a license.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Make sure to not customize ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":" before the completion block is called, otherwise your changes may be overwritten.","type":"text"}]},{"anchor":"Step-4-Customize-the-keyboard-view-optional","type":"heading","level":2,"text":"Step 4. Customize the keyboard view (optional)"},{"type":"paragraph","inlineContent":[{"text":"To replace or customize the default ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardView","isActive":true,"type":"reference"},{"text":", just override ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/viewWillSetupKeyboardView()","isActive":true,"type":"reference"},{"text":" and call ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/setupKeyboardView(_:)","isActive":true,"type":"reference"},{"text":" with the view that you want to use:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewWillSetupKeyboardView() {","        setupKeyboardView { [weak self] controller in \/\/ <-- Use weak or unknowned if you must use self!","            CustomKeyboardView(","                services: controller.services","            )","        }","    }","}","","\/\/ Defining a custom view in a separate file keeps your controller clean.","struct CustomKeyboardView: View {","","    var services: Keyboard.Services","","    \/\/ All observable contexts are added to the enviroment.","    @EnvironmentObject private var keyboardContext: KeyboardContext","","    var body: some View {","        if keyboardContext ... {","            \/\/ You can customize your keyboard view for any observable state,","            \/\/ including your own custom observable state.","        } else {","            KeyboardView(","                services: services,","                buttonContent: { $0.view },        \/\/ Use $0.view to use the standard view","                buttonView: { $0.view },           \/\/ The $0 arg has additional properties             ","                collapsedView: { params in params.view },   \/\/ This is the same as $0.view","                emojiKeyboard: { $0.view },        ","                toolbar: { _ in CustomToolbar() }  \/\/ You can customize any view like this","            )","        }","    }","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Passing the controller into a keyboard view can easily result in a memory leak, if you forget to make the controller reference weak or unowned. The "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/setupKeyboardView(_:)","type":"reference","isActive":true},{"type":"text","text":" view builder provides an unowned controller reference to avoid memory leaks. If you must refer to your specific controller type, you MUST use "},{"type":"codeVoice","code":"[weak self]"},{"type":"text","text":" or "},{"type":"codeVoice","code":"[unowned self]"},{"type":"text","text":"!"}]}],"type":"aside","name":"Important"},{"anchor":"Step-5-Set-up-the-main-app-optional","type":"heading","level":2,"text":"Step 5. Set up the main app (optional)"},{"type":"paragraph","inlineContent":[{"text":"The main app can be used to display the enabled and Full Access status of your keyboard, link to Settings, etc. It’s also a great place for keyboard settings, since it has more space than the keyboard extension.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The easiest way to set up an app target is to use ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView","isActive":true,"type":"reference"},{"text":" as the root view, with the same ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","isActive":true,"type":"reference"},{"text":" as the keyboard:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .myApp) {","                ContentView() \/\/ <-- Your specific app root","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"This will set up your main app the same way as your keyboard, register your license before rendering the content view, etc. You can use any content view, and use any Pro features since the view is redrawn when a license is registered.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/App-Article","isActive":true,"type":"reference"},{"text":" for more information about how to easily set up a full-blown keyboard app with KeyboardKit Pro’s various app utilities.","type":"text"}]},{"anchor":"Step-6-Customize-state--services-optional","type":"heading","level":2,"text":"Step 6. Customize state & services (optional)"},{"type":"paragraph","inlineContent":[{"text":"The main ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController","isActive":true,"type":"reference"},{"text":" provides you with keyboard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/state","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/services","isActive":true,"type":"reference"},{"text":", to let you build great keyboards.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can change any observable state at any time, to affect the keyboard. For instance, changing the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardContext\/keyboardType","isActive":true,"type":"reference"},{"text":" will automatically redraw the keyboard. Each observable context also has its own auto-persisted ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardContext\/settings","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit will inject all observable context types into the environment. This means that you can access them from anywhere, like this:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct CustomView: View {","","    @EnvironmentObject private var keyboardContext: KeyboardContext","    ","    var body: some View {","        ...","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"You can replace any services with custom implementations. For instance, here we replace the standard ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardActionHandler","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["class KeyboardViewController: KeyboardInputViewController {","","    override func viewDidLoad() {","        super.viewDidLoad()","        setup(for: .myApp) { [weak self] _ in","            guard let self else { return }","            self.services.actionHandler = CustomActionHandler(controller: self)    ","        }","    }","}","","class CustomActionHandler: KeyboardAction.StandardActionHandler {","","    open override func handle(_ action: KeyboardAction) {","        if action == .space {","            print(\"Pressed space!\")","        }","        super.handle(action) ","    }","}"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Any keyboard customizations that rely on Pro features must be made within the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/setup(for:completion:)","type":"reference","isActive":true},{"type":"text","text":" completion block."}]}],"type":"aside","name":"Important"},{"anchor":"Bonus-Setting-up-KeyboardKit-as-a-package-dependency","type":"heading","level":2,"text":"Bonus - Setting up KeyboardKit as a package dependency"},{"type":"paragraph","inlineContent":[{"text":"To set up KeyboardKit as a package dependency, just add it to your package’s dependencies list and link it to any target that needs it.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["...","dependencies: [","    .package(","        url: \"https:\/\/github.com\/KeyboardKit\/KeyboardKit.git\",","        .upToNextMajor(from: \"10.0.0\")","    )","],","targets: [","    .target(","        name: \"MyPackage\",","        dependencies: [\"KeyboardKit\"]","    )","]"]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Since KeyboardKit is a binary package, you don’t have to link it to targets that use "},{"inlineContent":[{"text":"your","type":"text"}],"type":"emphasis"},{"type":"text","text":" package, but a target "},{"inlineContent":[{"text":"must","type":"text"}],"type":"emphasis"},{"type":"text","text":" update "},{"inlineContent":[{"text":"runpath search paths","type":"text"}],"type":"strong"},{"type":"text","text":" under its Build Settings. Use "},{"inlineContent":[{"text":"@executable_path\/Frameworks","type":"text"}],"type":"strong"},{"type":"text","text":" for apps and "},{"inlineContent":[{"text":"@executable_path\/..\/..\/Frameworks","type":"text"}],"type":"strong"},{"type":"text","text":" for keyboards. Failing to set the search paths will cause a runtime crash."}]}],"type":"aside","name":"Important"},{"anchor":"Thats-it","type":"heading","level":2,"text":"That’s it!"},{"type":"paragraph","inlineContent":[{"text":"You should now have a fully functional keyboard extension and companion app, which you can customize even further to fit your needs. For more information, see the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Essentials-Article","isActive":true,"type":"reference"},{"text":" article, as well as the other articles in this documentation.","type":"text"}]},{"type":"thematicBreak"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Getting Started","modules":[{"name":"KeyboardKit"}]},"references":{"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/KeyboardInputViewController/viewDidLoad()":{"abstract":[],"kind":"symbol","title":"viewDidLoad()","type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/viewDidLoad()","navigatorTitle":[{"text":"viewDidLoad","kind":"identifier"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"viewDidLoad","kind":"identifier"},{"text":"()","kind":"text"}],"url":"\/documentation\/keyboardkit\/keyboardinputviewcontroller\/viewdidload()","role":"symbol"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/KeyboardInputViewController/setup(for:completion:)":{"abstract":[{"type":"text","text":"Set up KeyboardKit for the provided app."}],"kind":"symbol","title":"setup(for:com