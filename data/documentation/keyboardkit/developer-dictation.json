{"identifier":{"url":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Dictation","interfaceLanguage":"swift"},"metadata":{"role":"article","modules":[{"name":"KeyboardKit"}],"roleHeading":"Article","images":[{"type":"card","identifier":"Feature-Dictation.jpg"}],"color":{"standardColorIdentifier":"purple"},"title":"Dictation"},"abstract":[{"text":"This developer guide describes how to set up and customize dictation.","type":"text"}],"seeAlsoSections":[{"anchor":"Features","identifiers":["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Actions","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Autocomplete","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Feedback","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Localization","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Themes"],"title":"Features","generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/keyboardkit\/developer-dictation"]},{"paths":["\/documentation\/keyboardkit\/developer-dictation"],"traits":[{"interfaceLanguage":"occ"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Guides"],["doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Features-Articles","doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation-Article"]]},"kind":"article","primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit makes it easy to perform dictation directly from the keyboard extension, in a way where the keyboard only has to open the main app to start dictation. See the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation-Article","isActive":true,"type":"reference"},{"text":" article for more information about this feature.","type":"text"}]},{"type":"aside","style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"text":"👑 Dictation requires a KeyboardKit Pro license with ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/ProFeature\/dictation","isActive":true,"type":"reference"},{"type":"text","text":" support, unless you want to implement the feature from scratch. You can sign up for KeyboardKit Pro from the "},{"type":"reference","identifier":"https:\/\/keyboardkit.com","isActive":true},{"type":"text","text":"."}]}]},{"anchor":"How-to-perform-dictation","level":2,"text":"How to perform dictation","type":"heading"},{"inlineContent":[{"text":"Dictation can be performed in the main ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/app","type":"reference"},{"text":" or its ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/keyboard","type":"reference"},{"text":" extension (which is the main use case for keyboard-based applications).","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Keyboard extensions must open the main app to start dictation. After this, dictation is performed based on the ","type":"text"},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationSettings\/dictationMethod","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/app","type":"reference"},{"text":" - Dictation is performed in the app, then navigates back to the keyboard to apply the result.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/keyboard"},{"type":"text","text":" (BETA) - Dictation is started in the app, then navigates back to the keyboard to perform dictation within the extension."}]}]}],"type":"unorderedList"},{"name":"Tip","style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/keyboard","isActive":true},{"type":"text","text":" method is recommended, but is currently opt-in. It can be enabled with the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Experiment\/keyboardDictation","isActive":true},{"type":"text","text":" experiment."}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"After setting up dictation as described below, you can start dictation by triggering the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/dictation","isActive":true},{"type":"text","text":" action in your keyboard extension."}],"type":"paragraph"},{"text":"How to set up dictation","level":2,"type":"heading","anchor":"How-to-set-up-dictation"},{"inlineContent":[{"type":"text","text":"Setting up dictation just involves adding the required permissions, setting up an App Group to enable "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Data-Syncing","isActive":true},{"type":"text","text":" between the main app and its keyboard, and setting up a speech recognizer. The steps below will guide you through this process."}],"type":"paragraph"},{"text":"Step 1. Required permissions","level":3,"type":"heading","anchor":"Step-1-Required-permissions"},{"inlineContent":[{"type":"text","text":"Before you can start dictation, you must add these required keys to your app’s "},{"code":"Info.plist","type":"codeVoice"},{"type":"text","text":", otherwise the app will crash at runtime:"}],"type":"paragraph"},{"syntax":null,"code":["<key>NSMicrophoneUsageDescription<\/key>","<string>Describe why you need microphone access.<\/string>","<key>NSSpeechRecognitionUsageDescription<\/key>","<string>Describe why you need speech recognition.<\/string>"],"type":"codeListing"},{"inlineContent":[{"text":"If you use the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/keyboard","isActive":true,"type":"reference"},{"text":" dictation method, you must also add background audio permissions to keep dictation alive in the background:","type":"text"}],"type":"paragraph"},{"syntax":null,"code":["<key>UIBackgroundModes<\/key>","<array>","    <string>audio<\/string>","<\/array>"],"type":"codeListing"},{"inlineContent":[{"identifier":"developer-dictation-background-modes","type":"image"}],"type":"paragraph"},{"inlineContent":[{"text":"If you don’t add this to the ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":", dictation will stop detecting speech and volume as soon as the app returns to the keyboard.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Step 2. Set up an App Group","anchor":"Step-2-Set-up-an-App-Group","type":"heading"},{"inlineContent":[{"type":"text","text":"To share data between your app and keyboard, you must setup an App Group for both targets, as described in the "},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Data-Syncing","type":"reference","isActive":true},{"type":"text","text":" article."}],"type":"paragraph"},{"level":3,"text":"Step 3. Set up a URL Scheme","anchor":"Step-3-Set-up-a-URL-Scheme","type":"heading"},{"inlineContent":[{"text":"To make it possible for the keyboard to open the app and start dictation, you must set up a deep link URL scheme to open the main app:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"image","identifier":"developer-dictation-url-scheme"}],"type":"paragraph"},{"inlineContent":[{"text":"The URL scheme must be unique for your app, for instance ","type":"text"},{"code":"myapp:\/\/","type":"codeVoice"},{"text":". Add this to your ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","type":"reference"},{"text":"’s ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/deepLinks-swift.property","type":"reference"},{"text":"  ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/DeepLinks-swift.struct\/app","type":"reference"},{"text":" property:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["KeyboardApp(..., deepLinks: .init(app: \"myapp:\/\/\"))"],"syntax":"swift"},{"inlineContent":[{"text":"KeyboardKit will use ","type":"text"},{"type":"codeVoice","code":"<SCHEME>dictation"},{"text":" as the default dictation deep link, but you can customize this if it conflicts with your app.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Step-4-Create-a-Speech-Recognizer","type":"heading","text":"Step 4. Create a Speech Recognizer"},{"inlineContent":[{"type":"text","text":"KeyboardKit uses a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationSpeechRecognizer"},{"type":"text","text":" protocol to decouple KeyboardKit from the Speech framework, to avoid having to add dictation permissions in apps that don’t use dictation."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Instead, you can copy this standard speech recognizer and add it to your app, then inject it with "},{"code":".standard","type":"codeVoice"},{"type":"text","text":" when setting up dictation:"}],"type":"paragraph"},{"type":"codeListing","code":["import KeyboardKit","import Speech","","public extension DictationSpeechRecognizer where Self == StandardSpeechRecognizer {","","    static var standard: Self { .init() }","} ","","public class StandardSpeechRecognizer: DictationSpeechRecognizer {","","    public init() {}","","    private var recognizer: SFSpeechRecognizer?","    private var request: SFSpeechAudioBufferRecognitionRequest?","    private var speechRecognizerTask: SFSpeechRecognitionTask?","","    private typealias Err = Dictation.ServiceError","","    public var authorizationStatus: Dictation.AuthorizationStatus {","        SFSpeechRecognizer.authorizationStatus().keyboardDictationStatus","    }","","    public var supportedLocales: [Locale] {","        Array(SFSpeechRecognizer.supportedLocales())","    }","","    public func requestDictationAuthorization() async throws -> Dictation.AuthorizationStatus {","        await withCheckedContinuation { continuation in","            SFSpeechRecognizer.requestAuthorization { status in","                continuation.resume(returning: status.keyboardDictationStatus)","            }","        }","    }","","    public func resetDictationResult() async throws {}","","    public func startDictation(","        with locale: Locale","    ) async throws {","        try await startDictation(","            with: locale,","            resultHandler: nil","        )","    }","","    public func startDictation(","        with locale: Locale,","        resultHandler: ((Dictation.SpeechRecognizerResult) -> Void)?","    ) async throws {","        recognizer = SFSpeechRecognizer(locale: locale)","        guard let recognizer else { throw Err.missingSpeechRecognizer }","        request = SFSpeechAudioBufferRecognitionRequest()","        request?.shouldReportPartialResults = true","        guard let request else { throw Err.missingSpeechRecognitionRequest }","        speechRecognizerTask = recognizer.recognitionTask(with: request) {","            let result = Dictation.SpeechRecognizerResult(","                dictatedText: $0?.bestTranscription.formattedString,","                error: $1,","                isFinal: $0?.isFinal ?? true)","            resultHandler?(result)","        }","    }","","    public func stopDictation() async throws {","        request?.endAudio()","        request = nil","        speechRecognizerTask?.cancel()","        speechRecognizerTask = nil","    }","","    public func setupAudioEngineBuffer(_ buffer: AVAudioPCMBuffer) {","        request?.append(buffer)","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"The standard speech recognizer uses the Speech framework to perform local, on-device recognition. It supports the following locales:","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Arabic (ar-SA), Cantonese (yue-CN), Catalan (ca-ES), Chinese (zh-CN), Chinese (zh-HK), Chinese (zh-TW), Croatian (hr-HR), Czech (cs-CZ), Danish (da-DK), Dutch (nl-BE), Dutch (nl-NL), English (en-AE), English (en-AU), English (en-CA), English (en-GB), English (en-ID), English (en-IE), English (en-IN), English (en-NZ), English (en-PH), English (en-SA), English (en-SG), English (en-US), English (en-ZA), Finnish (fi-FI), French (fr-BE), French (fr-CA), French (fr-CH), French (fr-FR), German (de-AT), German (de-CH), German (de-DE), Greek (el-GR), Hebrew (he-IL), Hindi (hi-IN), Hindi (hi-IN-translit), Hindi (hi-Latn), Hungarian (hu-HU), Indonesian (id-ID), Italian (it-CH), Italian (it-IT), Japanese (ja-JP), Korean (ko-KR), Malay (ms-MY), Norwegian Bokmål (nb-NO), Polish (pl-PL), Portuguese (pt-BR), Portuguese (pt-PT), Romanian (ro-RO), Russian (ru-RU), Shanghainese (wuu-CN), Slovak (sk-SK), Spanish (es-419), Spanish (es-CL), Spanish (es-CO), Spanish (es-ES), Spanish (es-MX), Spanish (es-US), Swedish (sv-SE), Thai (th-TH), Turkish (tr-TR), Ukrainian (uk-UA), Vietnamese (vi-VN)"}],"type":"paragraph"},{"inlineContent":[{"text":"You can also implement the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationSpeechRecognizer","isActive":true,"type":"reference"},{"text":" protocol from scratch, for instance to perform speech recognition with a custom AI model or framework that supports more languages.","type":"text"}],"type":"paragraph"},{"level":3,"anchor":"Step-5-Set-up-your-Keyboard-Extension","type":"heading","text":"Step 5. Set up your Keyboard Extension"},{"inlineContent":[{"type":"text","text":"To set up dictation for your keyboard extension, just set it up with a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp"},{"type":"text","text":" with the app group and deep links from above. See the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Getting-Started-Article"},{"type":"text","text":" article for more information."}],"type":"paragraph"},{"level":3,"anchor":"Step-6-Set-up-your-Main-Application","type":"heading","text":"Step 6. Set up your Main Application"},{"inlineContent":[{"text":"To set up dictation for the main app, use a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView"},{"text":" with the same ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","type":"reference"},{"type":"text","text":", then apply the dictation view modifier:"}],"type":"paragraph"},{"type":"codeListing","code":["struct ContentView: View {","","    @Environment(\\.openURL) var openURL","    ","    @EnvironmentObject var dictationContext: DictationContext","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: some View {","        Text(\"Insert app here :)\")","            .keyboardDictation(","                speechRecognizer: .standard \/\/ The one we just created, or a custom one.","            )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMethod\/app"},{"text":" dictation method, you should also present a view when the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationContext\/dictationState"},{"text":" is ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationState\/active"},{"text":", e.g. a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/ProgressView"},{"text":".","type":"text"}]},{"type":"heading","level":3,"text":"Step 7. Start dictation","anchor":"Step-7-Start-dictation"},{"type":"paragraph","inlineContent":[{"text":"You can now start dictation in your keyboard by triggering a ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAction\/dictation","isActive":true,"type":"reference"},{"text":" action or by calling ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationService\/startDictationFromKeyboard()","isActive":true,"type":"reference"},{"text":", or use ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationService\/startDictationInApp()","isActive":true,"type":"reference"},{"text":" to perform in-app dictation.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationContext","isActive":true},{"type":"text","text":" will be updated when dictation is active. The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardView","isActive":true},{"type":"text","text":" will automatically replace the keyboard with a dictation "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/ProgressView","isActive":true},{"type":"text","text":" when the context’s "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationContext\/dictationState","isActive":true},{"type":"text","text":" is "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationState\/active","isActive":true},{"type":"text","text":", but you can use any view you like."}]},{"type":"heading","level":3,"text":"Step 8. Navigating between the keyboard and its main app","anchor":"Step-8-Navigating-between-the-keyboard-and-its-main-app"},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit will open the main application to start dictation, then return to the keyboard extension based on the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationSettings\/dictationMethod","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"KeyboardKit uses its "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Host-Article"},{"type":"text","text":" capabilities to "},{"type":"emphasis","inlineContent":[{"type":"text","text":"try"}]},{"type":"text","text":" to identify the keyboard host application. If successful, it can navigate back to the host application with a deep link to proceed with dictation, without any handling on your side."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the host application is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" known or can’t be opened, the user can still tap the top leading back arrow to navigate back to the last app. If the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationContext","isActive":true},{"type":"text","text":"’s "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardHostApplicationProvider\/hostApplication","isActive":true},{"type":"text","text":" property is nil, you should point your users to that arrow."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"See the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Host-Article"},{"type":"text","text":" article for more information on which apps that are currently supported, and how to add more apps to this list."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Developer-Themes":{"url":"\/documentation\/keyboardkit\/developer-themes","kind":"article","title":"Themes","type":"topic","images":[{"identifier":"Feature-Themes.jpg","type":"card"}],"abstract":[{"type":"text","text":"This developer guide describes how to create custom keyboard themes."}],"role":"article","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Themes"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Experiment/keyboardDictation":{"abstract":[{"type":"text","text":"Keyboard dictation performs dictation in the keyboard."}],"type":"topic","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"keyboardDictation","kind":"identifier"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Experiment\/keyboardDictation","title":"Experiment.keyboardDictation","kind":"symbol","url":"\/documentation\/keyboardkit\/experiment\/keyboarddictation"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Developer-Data-Syncing":{"url":"\/documentation\/keyboardkit\/developer-data-syncing","type":"topic","images":[{"type":"card","identifier":"Developer-Article-Data-Syncing.jpg"}],"title":"Data Syncing","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Developer-Data-Syncing","role":"article","abstract":[{"type":"text","text":"This developer guide describes how to sync data between the main app and its keyboard."}],"kind":"article"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Getting-Started-Article":{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Getting-Started-Article","abstract":[{"type":"text","text":"This developer guide describes how to get started with KeyboardKit."}],"kind":"article","role":"article","type":"topic","url":"\/documentation\/keyboardkit\/getting-started-article","title":"Getting Started"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/DictationSettings/dictationMethod":{"abstract":[{"text":"The dictation method to use, by default ","type":"text"},{"type":"codeVoice","code":".app"},{"text":".","type":"text"}],"type":"topic","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationSettings\/dictationMethod","title":"dictationMethod","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"dictationMethod","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:11KeyboardKit9DictationV","text":"Dictation"},{"text":".","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:11KeyboardKit9DictationV0C6MethodO","text":"DictationMethod"}],"url":"\/documentation\/keyboardkit\/dictationsettings\/dictationmethod","role":"symbol"},"developer-dictation-background-modes":{"alt":"Xcode Background Modes","type":"image","variants":[{"url":"\/images\/com.keyboardkit.KeyboardKit\/developer-dictation-background-modes.jpg","traits":["1x","light"]}],"identifier":"developer-dictation-background-modes"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Dictation/ProgressView":{"kind":"symbol","url":"\/documentation\/keyboardkit\/dictation\/progressview","title":"Dictation.ProgressView","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ProgressView"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"ProgressView"}],"abstract":[{"type":"text","text":"This view can be used to visualize ongoing dictation"},{"type":"text","text":" "},{"type":"text","text":"progress and let users cancel or apply."}],"role":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/ProgressView"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/KeyboardApp/DeepLinks-swift.struct/app":{"url":"\/documentation\/keyboardkit\/keyboardapp\/deeplinks-swift.struct\/app","kind":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/DeepLinks-swift.struct\/app","role":"symbol","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"app"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"}],"title":"app","type":"topic","abstract":[{"type":"text","text":"A deep link for opening the app."}]},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Dictation/DictationMethod/keyboard":{"role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"keyboard"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationMetho