d":"text","text":" "},{"kind":"identifier","text":"DictationContext"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/DictationContext","navigatorTitle":[{"kind":"identifier","text":"DictationContext"}],"title":"DictationContext","role":"symbol","url":"\/documentation\/keyboardkit\/dictationcontext"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Dictation/ProgressView":{"url":"\/documentation\/keyboardkit\/dictation\/progressview","navigatorTitle":[{"text":"ProgressView","kind":"identifier"}],"abstract":[{"type":"text","text":"This view can be used to visualize ongoing dictation"},{"type":"text","text":" "},{"type":"text","text":"progress and let users cancel or apply."}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProgressView","kind":"identifier"}],"role":"symbol","type":"topic","title":"Dictation.ProgressView","kind":"symbol","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/ProgressView"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/KeyboardHostApplication/allCases":{"type":"topic","abstract":[],"kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"text":"allCases","kind":"identifier"},{"text":": [`Self`","kind":"text"},{"text":"]","kind":"text"}],"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardHostApplication\/allCases","title":"allCases","role":"symbol","url":"\/documentation\/keyboardkit\/keyboardhostapplication\/allcases"},"doc://com.keyboardkit.KeyboardKit/documentation/KeyboardKit/Dictation/DictationState/active":{"url":"\/documentation\/keyboardkit\/dictation\/dictationstate\/active","title":"Dictation.DictationState.active","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Dictation\/DictationState\/active","role":"symbol","kind":"symbol","abstract":[