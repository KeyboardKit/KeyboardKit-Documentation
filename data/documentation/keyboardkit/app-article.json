:"occ"}],"paths":["\/documentation\/keyboardkit\/app-article"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/App-Article"},"sections":[],"primaryContentSections":[{"content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"KeyboardKit has app-specific utilities to help you build a great main app for your keyboard, sync data between the app & keyboard, etc."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","isActive":true},{"type":"text","text":" struct can be used to set up both your keyboard and main app, while the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView","isActive":true},{"type":"text","text":" can be used to set up the main app and render the content view once your KeyboardKit Pro license is validated."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the main app, the "},{"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/HomeScreen","isActive":true},{"type":"text","text":" and various screen templates lets you set up a complete keyboard app with just a few lines of code."}]},{"type":"heading","anchor":"Namespace","text":"Namespace","level":2},{"type":"paragraph","inlineContent":[{"text":"KeyboardKit has an ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","isActive":true,"type":"reference"},{"text":" namespace with app-related types.","type":"text"}]},{"type":"heading","anchor":"App-Information","text":"App Information","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp"},{"type":"text","text":" struct can be used to describe your app and its configuration, and serves as a namespace for app-specific types."}]},{"type":"paragraph","inlineContent":[{"text":"You can create an app-specific ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp","isActive":true,"type":"reference"},{"text":" value to set up your app and keyboard. See the ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Getting-Started-Article","isActive":true,"type":"reference"},{"text":" guide for more details.","type":"text"}]},{"anchor":"Context","level":2,"type":"heading","text":"Context"},{"inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext"},{"text":" class with observable state and auto-persisted app ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext\/settings"},{"text":". It has values like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext\/openReason"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext\/openReasonCase"},{"text":", to let you know why the main app was opened by the keyboard.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Since Apple restricts keyboards from knowing about their host app, and restricts the main app from returning to the keyboard, you can use the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext\/openReason"},{"text":" to determine if you should present a message to show the user how to tap the top leading back button to return to the keyboard. For instance, opening the main app from the keyboard to start the dictation engine will set the reason to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardApp\/OpenReason\/dictation"},{"text":".  The reason will auto-reset when the main app is sent to the background.","type":"text"}]}],"name":"Tip","type":"aside","style":"tip"},{"inlineContent":[{"text":"KeyboardKit automatically creates an instance of this class and registers it with its ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController\/state","type":"reference"},{"text":", and also injects it into the view environment.","type":"text"}],"type":"paragraph"},{"anchor":"Settings","level":2,"type":"heading","text":"Settings"},{"inlineContent":[{"text":"KeyboardKit has a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppSettings"},{"text":" type with auto-persisted settings. This is currently only used for internal persistency, but may be extended in the future. The context ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppContext\/settings"},{"text":" is used by default.","type":"text"}],"type":"paragraph"},{"anchor":"Views","level":2,"type":"heading","text":"Views"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView"},{"text":" should be used as the root view of your main app. It will set up the app, make ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Foundation\/UserDefaults\/keyboardSettings"},{"text":" sync data between the app and keyboard, set up KeyboardKit Pro, etc. See ","type":"text"},{"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Getting-Started-Article","isActive":true,"type":"reference"},{"text":" for more information.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The  ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView","type":"reference"},{"text":" will also inject observable keyboard ","type":"text"},{"isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/Keyboard\/State","type":"reference"},{"text":" types into the view environment, to let you access them like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","","    var body: some Scene {","        WindowGroup {","            KeyboardAppView(for: .myApp) {","                ContentView() \/\/ <-- Your specific app root view","            }","        }","    }","}","","struct ContentView: View {","","    @EnvironmentObject var keyboardContext: KeyboardContext","","    var body: View {","        YourMainContentView()","            .keyboardDictation(...) \/\/ <-- Keyboard-specific modifiers go here ","    }","}"]},{"inlineContent":[{"type":"text","text":"Unlike the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardInputViewController"},{"type":"text","text":", the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardAppView"},{"type":"text","text":" will also inject a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.keyboardkit.KeyboardKit\/documentation\/KeyboardKit\/KeyboardStatusContext"},